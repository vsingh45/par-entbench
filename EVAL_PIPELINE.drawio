  <diagram id="eval-pipeline" name="Evaluation Pipeline">
    <mxGraphModel dx="1200" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Execution-Based Evaluation Pipeline" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="0" y="20" width="1200" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1: Task Definition -->
        <mxCell id="step1" value="1. Task&#xa;JSON definition&#xa;from EntBench&#xa;(54 tasks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edff;strokeColor=#0066cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Step 2: Planner + Router -->
        <mxCell id="step2" value="2. Plan &amp; Route&#xa;Decompose into&#xa;subtasks, assign&#xa;tier per router" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edff;strokeColor=#0066cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="80" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow 1-2 -->
        <mxCell id="arrow12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Execute -->
        <mxCell id="step3" value="3. Execute&#xa;Specialist runs&#xa;with tier-specific&#xa;model (H,S,O)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edff;strokeColor=#0066cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow 2-3 -->
        <mxCell id="arrow23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: Hit DB -->
        <mxCell id="step4" value="4. Hit DB&#xa;Execute query/&#xa;pipeline on live&#xa;Postgres/MongoDB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#856404;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow 3-4 -->
        <mxCell id="arrow34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: Evaluate -->
        <mxCell id="step5" value="5. Evaluate&#xa;Task-specific&#xa;scorer: F1,&#xa;accuracy, exact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#155724;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="740" y="80" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow 4-5 -->
        <mxCell id="arrow45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6: Log Result -->
        <mxCell id="step6" value="6. Result&#xa;JSON with&#xa;accuracy, cost,&#xa;latency, tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edff;strokeColor=#0066cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow 5-6 -->
        <mxCell id="arrow56" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Annotation: What Makes Different -->
        <mxCell id="note1" value="What Makes EntBench Different:&#xa;• Live infrastructure: queries execute against real Postgres/MongoDB&#xa;• Execution-based: verdict depends on DB result, not just output&#xa;• Fair accounting: judge scorer cost (FrugalGPT) included" style="text;align=left;fontSize=11;fillColor=none;strokeColor=#999;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="260" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Annotation: Routers -->
        <mxCell id="note2" value="Routers Tested (Step 2):&#xa;PaR: planner assigns tier&#xa;AllFrontier: every node → Opus&#xa;AllSmall: every node → Haiku&#xa;SinkFrontier: Opus on leaves&#xa;SourceFrontier: Opus on root&#xa;FrugalGPT: cascade + LLM judge" style="text;align=left;fontSize=11;fillColor=none;strokeColor=#999;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="260" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Annotation: Measured -->
        <mxCell id="note3" value="Measured Per Task (Step 6):&#xa;accuracy: task_correct (bool)&#xa;cost: tokens × model pricing&#xa;latency: end-to-end milliseconds&#xa;per-node tiers assigned&#xa;ρ (rho): composition penalty&#xa;  = planner vs oracle cost ratio" style="text;align=left;fontSize=11;fillColor=none;strokeColor=#999;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="260" width="280" height="120" as="geometry" />
        </mxCell>

