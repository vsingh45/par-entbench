    "commands": {
      "final_sweep": "par-entbench --tasks all --routers all --seeds 3 --output results/final_sweep/ --kill-switch-usd 70",
      "standalone": "par-entbench --tasks capability_calibration --routers all_tiers --seeds 1 --output results/standalone/",
      "rho": "par-entbench --compute-rho results/final_sweep/ --standalone results/standalone/ --rho-output results/rho_analysis.json"
    }
