      "output": {
        "sql": "SELECT cf.product, SUM(cf.amount_usd) as q4_2024_spend, AVG(cf.daily_active_seats) as avg_daily_seats, COUNT(DISTINCT cf.event_date) as active_days, SUM(cf.daily_active_seats)::NUMERIC / NULLIF(COUNT(DISTINCT cf.event_date), 0) as daily_consumption_rate, cf.fiscal_year, cf.fiscal_quarter FROM consumption_facts cf WHERE cf.publisher = 'Adobe' AND cf.event_date >= '2024-10-01' AND cf.event_date <= '2024-12-31' AND cf.fiscal_year = 2024 AND cf.fiscal_quarter = 4 GROUP BY cf.product, cf.fiscal_year, cf.fiscal_quarter ORDER BY q4_2024_spend DESC"
