      "output": {
        "sql": "SELECT cf.product, cf.license_id, DATE_TRUNC('month', cf.event_date)::DATE as month, COUNT(DISTINCT cf.user_id) as active_users, SUM(cf.daily_active_seats) as total_active_seats, SUM(cf.amount_usd) as total_spend_usd, COUNT(DISTINCT cf.event_id) as event_count FROM consumption_facts cf WHERE cf.event_date >= '2024-01-01' AND cf.publisher = 'Microsoft' GROUP BY cf.product, cf.license_id, DATE_TRUNC('month', cf.event_date) ORDER BY month DESC, cf.product, cf.license_id"
