        "collection": "sam_licenses",
        "pipeline": [
          {
            "$match": {
              "publisher": "Microsoft"
            }
          },
          {
            "$lookup": {
              "from": "sam_seat_assignments",
              "localField": "license_id",
              "foreignField": "license_id",
              "as": "seat_assignments"
            }
          },
          {
            "$group": {
              "_id": {
                "product": "$product",
                "license_id": "$license_id"
              },
              "assigned_user_count": {
                "$size": "$seat_assignments"
              },
              "licensed_seat_count": {
                "$first": "$seat_count"
              },
              "cost_per_seat": {
                "$first": "$cost_per_seat_usd"
              },
              "contract_value": {
                "$first": "$contract_value_usd"
              },
              "status": {
                "$first": "$status"
              },
              "term_start": {
                "$first": "$term_start"
              },
              "term_end": {
                "$first": "$term_end"
              }
            }
          },
          {
            "$group": {
              "_id": "$_id.product",
              "total_licensed_seats": {
                "$sum": "$licensed_seat_count"
              },
              "total_assigned_users": {
                "$sum": "$assigned_user_count"
              },
              "total_contract_value": {
                "$sum": "$contract_value"
              },
              "license_details": {
                "$push": {
                  "license_id": "$_id.license_id",
                  "assigned_users": "$assigned_user_count",
                  "licensed_seats": "$licensed_seat_count",
                  "utilization_rate": {
                    "$divide": [
                      "$assigned_user_count",
                      "$licensed_seat_count"
                    ]
                  },
                  "status": "$status"
                }
              }
            }
          },
          {
            "$addFields": {
              "provisioning_variance": {
                "$subtract": [
                  "$total_licensed_seats",
                  "$total_assigned_users"
                ]
              },
              "overall_utilization_rate": {
                "$divide": [
                  "$total_assigned_users",
                  "$total_licensed_seats"
                ]
              },
              "cost_per_active_user": {
                "$divide": [
                  "$total_contract_value",
                  "$total_assigned_users"
                ]
              }
            }
          }
        ]
      },
