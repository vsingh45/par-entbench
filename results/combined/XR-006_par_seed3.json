        "sql": "SELECT DATE_TRUNC('month', event_date) AS usage_month, COUNT(DISTINCT user_id) AS monthly_active_users, AVG(daily_active_seats) AS avg_daily_active_seats, MAX(daily_active_seats) AS peak_concurrent_seats, SUM(amount_usd) AS total_spend, COUNT(DISTINCT license_id) AS active_licenses, LAG(COUNT(DISTINCT user_id)) OVER (ORDER BY DATE_TRUNC('month', event_date)) AS prev_month_mau, ROUND( 100.0 * (COUNT(DISTINCT user_id) - LAG(COUNT(DISTINCT user_id)) OVER (ORDER BY DATE_TRUNC('month', event_date))) / NULLIF(LAG(COUNT(DISTINCT user_id)) OVER (ORDER BY DATE_TRUNC('month', event_date)), 0), 2 ) AS mau_growth_rate_pct, ROUND( AVG(daily_active_seats)::NUMERIC / NULLIF(COUNT(DISTINCT user_id), 0), 4 ) AS dau_mau_ratio FROM consumption_facts WHERE product ILIKE '%slack%' AND event_date >= CURRENT_DATE - INTERVAL '18 months' GROUP BY DATE_TRUNC('month', event_date) ORDER BY usage_month ASC}"
