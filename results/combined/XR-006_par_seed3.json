          {
            "$lookup": {
              "from": "sam_seat_assignments",
              "localField": "license_id",
              "foreignField": "license_id",
              "as": "seat_assignments"
            }
          },
          {
            "$addFields": {
              "total_assigned_seats": {
                "$size": "$seat_assignments"
              },
              "active_assigned_seats": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "sa",
                    "cond": {
                      "$eq": [
                        "$$sa.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "inactive_or_dormant_seats": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "sa",
                    "cond": {
                      "$or": [
                        {
                          "$eq": [
                            "$$sa.last_active_date",
                            null
                          ]
                        },
                        {
                          "$not": [
                            {
                              "$ifNull": [
                                "$$sa.last_active_date",
                                false
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  }
                }
              },
              "seat_utilization_pct": {
                "$cond": {
                  "if": {
                    "$gt": [
                      "$seat_count",
                      0
                    ]
                  },
                  "then": {
                    "$multiply": [
                      {
                        "$divide": [
                          {
                            "$size": {
                              "$filter": {
                                "input": "$seat_assignments",
                                "as": "sa",
                                "cond": {
                                  "$eq": [
                                    "$$sa.status",
                                    "active"
                                  ]
                                }
                              }
                            }
                          },
                          "$seat_count"
                        ]
                      },
                      100
                    ]
                  },
                  "else": 0
                }
              },
              "days_until_renewal": {
                "$divide": [
                  {
                    "$subtract": [
                      "$term_end",
                      "$$NOW"
                    ]
                  },
                  86400000
                ]
              },
              "billing_contract": {
                "$arrayElemAt": [
                  "$billing_info",
                  0
                ]
              }
            }
          },
          {
            "$sort": {
              "term_end": 1
            }
          }
        ]
      },
