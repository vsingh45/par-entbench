      "output": {
        "sql": "SELECT cf.product, cf.publisher, COUNT(DISTINCT cf.license_id) as license_count, SUM(cf.daily_active_seats) as total_contracted_seats, MIN(cf.event_date) as allocation_start_date, MAX(cf.event_date) as allocation_end_date, cf.event_type as license_type, SUM(cf.amount_usd) as total_revenue_usd, COUNT(DISTINCT cf.user_id) as unique_users, AVG(cf.daily_active_seats) as avg_daily_active_seats FROM consumption_facts cf WHERE cf.publisher = 'Datadog' AND cf.event_date >= '2024-01-01' GROUP BY cf.product, cf.publisher, cf.event_type ORDER BY cf.product, total_contracted_seats DESC"
