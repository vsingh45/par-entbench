      "output": {
        "collection": "sam_licenses",
        "pipeline": [
          {
            "$match": {
              "publisher": "Datadog",
              "status": "active"
            }
          },
          {
            "$lookup": {
              "from": "sam_seat_assignments",
              "localField": "license_id",
              "foreignField": "license_id",
              "as": "seat_assignments"
            }
          },
          {
            "$addFields": {
              "allocated_seats": "$seat_count",
              "assigned_seats": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "assignment",
                    "cond": {
                      "$eq": [
                        "$$assignment.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "unassigned_seats": {
                "$subtract": [
                  "$seat_count",
                  {
                    "$size": {
                      "$filter": {
                        "input": "$seat_assignments",
                        "as": "assignment",
                        "cond": {
                          "$eq": [
                            "$$assignment.status",
                            "active"
                          ]
                        }
                      }
                    }
                  }
                ]
              }
            }
          },
          {
            "$group": {
              "_id": "$publisher",
              "total_contracts": {
                "$sum": 1
              },
              "total_allocated_seats": {
                "$sum": "$allocated_seats"
              },
              "total_assigned_seats": {
                "$sum": "$assigned_seats"
              },
              "total_unassigned_seats": {
                "$sum": "$unassigned_seats"
              },
              "total_contract_value": {
                "$sum": "$contract_value_usd"
              },
              "avg_cost_per_seat": {
                "$avg": "$cost_per_seat_usd"
              },
              "seat_utilization_pct": {
                "$multiply": [
                  {
                    "$divide": [
                      {
                        "$sum": "$assigned_seats"
                      },
                      {
                        "$sum": "$allocated_seats"
                      }
                    ]
                  },
                  100
                ]
              },
              "contracts": {
                "$push": {
                  "license_id": "$license_id",
                  "product": "$product",
                  "contract_value": "$contract_value_usd",
                  "allocated_seats": "$allocated_seats",
                  "assigned_seats": "$assigned_seats",
                  "term_start": "$term_start",
                  "term_end": "$term_end",
                  "criticality_tier": "$criticality_tier"
                }
              }
            }
          }
        ]
