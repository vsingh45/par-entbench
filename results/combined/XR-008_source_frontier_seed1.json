      "output": {
        "collection": "sam_licenses",
        "pipeline": [
          {
            "$match": {
              "publisher": "Datadog"
            }
          },
          {
            "$lookup": {
              "from": "sam_seat_assignments",
              "localField": "license_id",
              "foreignField": "license_id",
              "as": "assignments"
            }
          },
          {
            "$addFields": {
              "total_assigned": {
                "$size": "$assignments"
              },
              "active_users": {
                "$size": {
                  "$filter": {
                    "input": "$assignments",
                    "as": "a",
                    "cond": {
                      "$eq": [
                        "$$a.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "inactive_users": {
                "$size": {
                  "$filter": {
                    "input": "$assignments",
                    "as": "a",
                    "cond": {
                      "$ne": [
                        "$$a.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "users_with_recent_activity": {
                "$size": {
                  "$filter": {
                    "input": "$assignments",
                    "as": "a",
                    "cond": {
                      "$and": [
                        {
                          "$ne": [
                            "$$a.last_active_date",
                            null
                          ]
                        },
                        {
                          "$gte": [
                            "$$a.last_active_date",
                            {
                              "$dateSubtract": {
                                "startDate": "$$NOW",
                                "unit": "day",
                                "amount": 30
                              }
                            }
                          ]
                        }
                      ]
                    }
                  }
                }
              },
              "utilization_rate": {
                "$cond": [
                  {
                    "$gt": [
                      "$seat_count",
                      0
                    ]
                  },
                  {
                    "$divide": [
                      {
                        "$size": {
                          "$filter": {
                            "input": "$assignments",
                            "as": "a",
                            "cond": {
                              "$eq": [
                                "$$a.status",
                                "active"
                              ]
                            }
                          }
                        }
                      },
                      "$seat_count"
                    ]
                  },
                  0
                ]
              },
              "unused_seats": {
                "$subtract": [
                  "$seat_count",
                  {
                    "$size": {
                      "$filter": {
                        "input": "$assignments",
                        "as": "a",
                        "cond": {
                          "$eq": [
                            "$$a.status",
                            "active"
                          ]
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        ]
