  "node_results": [
    {
      "subtask_id": "mongo_slack_contracts",
      "specialist": "mongo_query",
      "tier_assigned": "mid",
      "model_used": "claude-sonnet-4-6",
      "input_tokens": 1221,
      "output_tokens": 724,
      "cached_tokens": 0,
      "latency_ms": 8647,
      "output": {
        "collection": "sam_licenses",
        "pipeline": [
          {
            "$match": {
              "publisher": "Slack",
              "status": {
                "$in": [
                  "active",
                  "pending_renewal",
                  "up_for_renewal"
                ]
              },
              "term_end": {
                "$gte": {
                  "$date": "2024-01-01T00:00:00Z"
                }
              }
            }
          },
          {
            "$lookup": {
              "from": "billing_contracts",
              "localField": "license_id",
              "foreignField": "contract_id",
              "as": "billing_info"
            }
          },
          {
            "$unwind": {
              "path": "$billing_info",
              "preserveNullAndEmpty": true
            }
          },
          {
            "$lookup": {
              "from": "sam_seat_assignments",
              "localField": "license_id",
              "foreignField": "license_id",
              "as": "seat_assignments"
            }
          },
          {
            "$addFields": {
              "active_seat_count": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "seat",
                    "cond": {
                      "$eq": [
                        "$$seat.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "inactive_seat_count": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "seat",
                    "cond": {
                      "$ne": [
                        "$$seat.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "days_until_renewal": {
                "$dateDiff": {
                  "startDate": "$$NOW",
                  "endDate": "$term_end",
                  "unit": "day"
                }
              },
              "renewal_urgency": {
                "$switch": {
                  "branches": [
                    {
                      "case": {
                        "$lte": [
                          {
                            "$dateDiff": {
                              "startDate": "$$NOW",
                              "endDate": "$term_end",
                              "unit": "day"
                            }
                          },
                          30
                        ]
                      },
                      "then": "critical"
                    },
                    {
                      "case": {
                        "$lte": [
                          {
                            "$dateDiff": {
                              "startDate": "$$NOW",
                              "endDate": "$term_end",
                              "unit": "day"
                            }
                          },
                          90
                        ]
                      },
                      "then": "upcoming"
                    },
                    {
                      "case": {
                        "$gt": [
                          {
                            "$dateDiff": {
                              "startDate": "$$NOW",
                              "endDate": "$term_end",
                              "unit": "day"
                            }
                          },
                          90
                        ]
                      },
                      "then": "future"
                    }
                  ],
                  "default": "unknown"
                }
              }
            }
          },
          {
            "$sort": {
              "term_end": 1
            }
          }
        ]
      },
      "node_correct": null,
      "error": null
    },
    {
      "subtask_id": "sql_slack_consumption",
      "specialist": "sql_gen",
      "tier_assigned": "mid",
      "model_used": "claude-sonnet-4-6",
      "input_tokens": 461,
      "output_tokens": 274,
      "cached_tokens": 0,
      "latency_ms": 4342,
      "output": {
        "sql": "SELECT cf.event_date, cf.product, cf.event_type, SUM(cf.daily_active_seats) AS total_daily_active_seats, COUNT(DISTINCT cf.user_id) AS distinct_users, SUM(cf.amount_usd) AS total_spend, AVG(cf.daily_active_seats) AS avg_daily_active_seats, MAX(cf.daily_active_seats) AS peak_daily_active_seats, MIN(cf.daily_active_seats) AS min_daily_active_seats, ROUND( AVG(cf.daily_active_seats) * 100.0 / NULLIF(MAX(cf.daily_active_seats) OVER (PARTITION BY cf.product), 0), 2 ) AS seat_utilization_rate_pct, COUNT(cf.event_id) AS event_count FROM consumption_facts cf WHERE cf.publisher ILIKE '%Slack%' OR cf.product ILIKE '%Slack%' GROUP BY cf.event_date, cf.product, cf.event_type ORDER BY cf.event_date ASC, cf.product, cf.event_type}"
      },
