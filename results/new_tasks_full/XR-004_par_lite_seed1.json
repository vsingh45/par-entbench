  "plan": {
    "subtasks": [
      {
        "id": "sam_query",
        "description": "Query SAM system for Microsoft licensed users and seat allocations by product/tenant",
        "specialist": "mongo_query",
        "tier": "mid",
        "depends_on": []
      },
      {
        "id": "consumption_query",
        "description": "Query consumption facts warehouse for active users and spend by Microsoft product/service",
        "specialist": "sql_gen",
        "tier": "mid",
        "depends_on": []
      },
      {
        "id": "reconciliation",
        "description": "Cross-reconcile SAM licensed seats against consumption active users, calculate provisioning gaps (under/over), generate classification (under-provisioned, optimized, over-provisioned) with recommendations",
        "specialist": "cross_recon",
        "tier": "frontier",
        "depends_on": [
          "sam_query",
          "consumption_query"
        ]
      }
    ],
    "cost_rationale": "Three subtasks: (1) mongo_query (mid tier) retrieves SAM licensing data with multi-document joins across license catalogs; (2) sql_gen (mid tier) aggregates consumption facts with multi-table joins to active user metrics; (3) cross_recon (frontier tier) performs multi-signal reconciliation across two sources with gap analysis, posture classification, and provisioning recommendations—this requires inference across license types, mapping of products, and nuanced under/over-provisioning logic that frontier capability provides. Frontier tier for cross_recon is necessary because the reconciliation must handle complex mappings between licensing SKUs and consumption metrics, calculate deltas, classify posture, and recommend action—a mid-tier agent cannot reliably infer the nuanced provisioning decisions across heterogeneous license dimensions."
  },
  "node_results": [
    {
      "subtask_id": "sam_query",
      "specialist": "mongo_query",
      "tier_assigned": "mid",
      "model_used": "claude-sonnet-4-6",
      "input_tokens": 1215,
      "output_tokens": 800,
      "cached_tokens": 0,
      "latency_ms": 9494,
      "output": {
        "collection": "sam_licenses",
        "pipeline": [
          {
            "$match": {
              "publisher": "Microsoft",
              "status": "active"
            }
          },
          {
            "$lookup": {
              "from": "sam_seat_assignments",
              "localField": "license_id",
              "foreignField": "license_id",
              "as": "seat_assignments"
            }
          },
          {
            "$addFields": {
              "total_assigned_seats": {
                "$size": "$seat_assignments"
              },
              "active_assigned_seats": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "sa",
                    "cond": {
                      "$eq": [
                        "$$sa.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "inactive_assigned_seats": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "sa",
                    "cond": {
                      "$ne": [
                        "$$sa.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "never_active_seats": {
                "$size": {
                  "$filter": {
                    "input": "$seat_assignments",
                    "as": "sa",
                    "cond": {
                      "$or": [
                        {
                          "$eq": [
                            "$$sa.last_active_date",
                            null
                          ]
                        },
                        {
                          "$not": [
                            {
                              "$gt": [
                                "$$sa.last_active_date",
                                null
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  }
                }
              },
              "unassigned_seats": {
                "$subtract": [
                  "$seat_count",
                  {
                    "$size": "$seat_assignments"
                  }
                ]
              }
            }
          },
          {
            "$addFields": {
              "provisioning_delta": {
                "$subtract": [
                  "$seat_count",
                  "$active_assigned_seats"
                ]
              },
              "provisioning_status": {
                "$switch": {
                  "branches": [
                    {
                      "case": {
                        "$gt": [
                          {
                            "$subtract": [
                              "$seat_count",
                              "$active_assigned_seats"
                            ]
                          },
                          0
                        ]
                      },
                      "then": "OVER_PROVISIONED"
                    },
                    {
                      "case": {
                        "$lt": [
                          {
                            "$subtract": [
                              "$seat_count",
                              "$active_assigned_seats"
                            ]
                          },
                          0
                        ]
                      },
                      "then": "UNDER_PROVISIONED"
                    }
                  ],
                  "default": "FULLY_UTILIZED"
                }
              },
              "wasted_spend_usd": {
                "$multiply": [
                  "$cost_per_seat_usd",
                  {
                    "$max": [
                      {
                        "$subtract": [
                          "$seat_count",
                          "$active_assigned_seats"
                        ]
                      },
                      0
                    ]
                  }
                ]
              },
              "utilization_pct": {
                "$cond": [
                  {
                    "$gt": [
                      "$seat_count",
                      0
                    ]
                  },
                  {
                    "$multiply": [
                      {
                        "$divide": [
                          "$active_assigned_seats",
                          "$seat_count"
                        ]
                      },
                      100
                    ]
                  },
                  0
                ]
              }
            }
          },
          {
            "$sort": {
              "wasted_spend_usd": -1
            }
          }
        ]
      },
      "node_correct": null,
      "error": null
    },
