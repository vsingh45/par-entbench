      "latency_ms": 3580,
      "output": {
        "sql": "SELECT product, SUM(amount_usd) AS total_spend_usd, SUM(daily_active_seats) AS total_active_seat_days, AVG(daily_active_seats) AS avg_daily_active_seats, COUNT(DISTINCT user_id) AS distinct_users, COUNT(DISTINCT license_id) AS distinct_licenses, COUNT(DISTINCT event_id) AS event_count, MIN(event_date) AS earliest_event, MAX(event_date) AS latest_event, SUM(CASE WHEN event_type = 'activation' THEN 1 ELSE 0 END) AS activations, SUM(CASE WHEN event_type = 'deactivation' THEN 1 ELSE 0 END) AS deactivations FROM consumption_facts WHERE publisher ILIKE '%microsoft%' GROUP BY product ORDER BY total_spend_usd DESC NULLS LAST"
      },
