      "output": {
        "collection": "sam_licenses",
        "pipeline": [
          {
            "$match": {
              "publisher": "Microsoft"
            }
          },
          {
            "$lookup": {
              "from": "sam_seat_assignments",
              "localField": "license_id",
              "foreignField": "license_id",
              "as": "assignments"
            }
          },
          {
            "$addFields": {
              "assigned_seats": {
                "$size": "$assignments"
              },
              "active_seats": {
                "$size": {
                  "$filter": {
                    "input": "$assignments",
                    "as": "a",
                    "cond": {
                      "$eq": [
                        "$$a.status",
                        "active"
                      ]
                    }
                  }
                }
              },
              "unused_seats": {
                "$subtract": [
                  "$seat_count",
                  {
                    "$size": "$assignments"
                  }
                ]
              },
              "utilization_pct": {
                "$cond": [
                  {
                    "$gt": [
                      "$seat_count",
                      0
                    ]
                  },
                  {
                    "$multiply": [
                      {
                        "$divide": [
                          {
                            "$size": "$assignments"
                          },
                          "$seat_count"
                        ]
                      },
                      100
                    ]
                  },
                  0
                ]
              },
              "wasted_spend_usd": {
                "$multiply": [
                  "$cost_per_seat_usd",
                  {
                    "$subtract": [
                      "$seat_count",
                      {
                        "$size": "$assignments"
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      },
