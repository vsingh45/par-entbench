          },
          {
            "$addFields": {
              "exercised_permissions": {
                "$reduce": {
                  "input": "$active_assignments",
                  "initialValue": [],
                  "in": {
                    "$setUnion": [
                      "$$value",
                      {
                        "$ifNull": [
                          "$$this.permissions_used",
                          []
                        ]
                      }
                    ]
                  }
                }
              }
            }
          },
          {
            "$addFields": {
              "granted_permissions": "$permissions",
              "unused_permissions": {
                "$setDifference": [
                  "$permissions",
                  "$exercised_permissions"
                ]
              },
              "used_permissions": {
                "$setIntersection": [
                  "$permissions",
                  "$exercised_permissions"
                ]
              },
              "total_granted": {
