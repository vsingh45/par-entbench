      "output": {
        "sql": "SELECT\n    al_granted.permission AS granted_permission,\n    al_granted.resource AS resource_scope,\n    al_granted.user_id AS role_or_user_id,\n    MIN(al_granted.access_time) AS first_grant_observed,\n    MAX(al_granted.access_time) AS last_grant_observed,\n    COUNT(al_granted.log_id) AS total_grant_events,\n    COALESCE(used.used_count, 0) AS times_exercised_last_180_days,\n    COALESCE(used.last_used, NULL) AS last_used_timestamp,\n    CASE\n        WHEN COALESCE(used.used_count, 0) = 0 THEN 'REVOCATION_CANDIDATE'\n        WHEN used.last_used < NOW() - INTERVAL '90 days' THEN 'STALE_USAGE'\n        ELSE 'ACTIVELY_USED'\n    END AS revocation_flag\nFROM access_log_facts al_granted\nLEFT JOIN (\n    SELECT\n        user_id,\n        permission,\n        resource,\n        COUNT(log_id) AS used_count,\n        MAX(access_time) AS last_used\n    FROM access_log_facts\n    WHERE\n        action != 'GRANT'\n        AND result = 'ALLOW'\n        AND access_time >= NOW() - INTERVAL '180 days'\n    GROUP BY user_id, permission, resource\n) used\n    ON al_granted.user_id = used.user_id\n    AND al_granted.permission = used.permission\n    AND al_granted.resource = used.resource\nWHERE\n    al_granted.action = 'GRANT'\n    AND al_granted.permission IN (\n        'admin', 'superuser', 'root', 'sudo', 'write_all', 'delete_all',\n        'manage_users', 'manage_roles', 'manage_permissions', 'full_access',\n        'elevated', 'privileged', 'owner', 'billing_admin', 'security_admin'\n    )\nGROUP BY\n    al_granted.permission,\n    al_granted.resource,\n    al_granted.user_id,\n    used.used_count,\n    used.last_used\nORDER BY\n    revocation_flag DESC,\n    al_granted.user_id,\n    al_granted.permission"
      },
